<?xml version="1.0" encoding="utf-8"?>
<!-- DOĞRULAMA KODU GİRİŞ ALANI: Premium Blue Focus Style -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ODAKLANILMIŞ DURUM -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A2563EB" />
            <stroke android:width="2dp" android:color="#992563EB" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- VARSAYILAN DURUM -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#990D1117" />
            <stroke android:width="1dp" android:color="#0FFFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
