<?xml version="1.0" encoding="utf-8"?>
<!-- HISTORY EMPTY STATE: Blue Glassmorphism -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="150%"
                android:centerX="50%"
                android:centerY="50%"
                android:startColor="#1A2563EB"
                android:endColor="#00000000" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <!-- Main Body -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#260D1117" />
            <corners android:radius="30dp" />
            <stroke
                android:width="1.2dp"
                android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
