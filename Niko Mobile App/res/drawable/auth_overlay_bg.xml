<?xml version="1.0" encoding="utf-8"?>
<!-- AUTH EKRANI ARKA PLAN: Premium Deep Blue Glassmorphism (Site Uyumlu) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ANA ARKA PLAN: Ultra Deep Navy (#080b14 site ile uyumlu) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#080b14"
                android:endColor="#0d1117"
                android:angle="270" />
        </shape>
    </item>
    
    <!-- SOL ÜST MAVİ IŞIMA (Primary Blue Glow) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="650dp"
                android:centerX="15%"
                android:centerY="10%"
                android:startColor="#1A2563EB"
                android:endColor="#00000000" />
        </shape>
    </item>
    
    <!-- ORTA SAĞ KOBALTİ IŞIMASI -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:centerX="85%"
                android:centerY="40%"
                android:startColor="#143B82F6"
                android:endColor="#00000000" />
        </shape>
    </item>
    
    <!-- ALT ORTA DEEP INDIGO IŞIMA -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="50%"
                android:centerY="90%"
                android:startColor="#1A1E40AF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- ÜST MERKEZ İNCE MAVİ ÇİZGİ (Card accent gibi) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="350dp"
                android:centerX="50%"
                android:centerY="5%"
                android:startColor="#0D3B82F6"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
