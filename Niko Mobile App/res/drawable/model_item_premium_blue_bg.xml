<?xml version="1.0" encoding="utf-8"?>
<!-- MODEL KARTI: Blue Premium Glassmorphism -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected State -->
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#262563EB"
                        android:centerColor="#1A0D1117"
                        android:endColor="#263B82F6" />
                    <corners android:radius="22dp" />
                    <stroke
                        android:width="2dp"
                        android:color="#4D3B82F6" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Normal State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#12FFFFFF" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF" />
        </shape>
    </item>
</selector>
